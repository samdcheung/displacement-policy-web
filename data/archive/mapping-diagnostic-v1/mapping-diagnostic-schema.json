{
  "schemaVersion": "2026-07-consolidated-v2",
  "title": "Displacement Governance Diagnostic",
  "description": "A canonical schema that preserves the black-letter and institutional record, diagnoses categorical, temporal and territorial fault lines, maps institutional interfaces and handoffs, identifies sustainable-inclusion mechanisms, and records continuity outcomes, political economy and evidence strength.",
  "conceptualModel": {
    "analyticalChain": [
      "displacementTransition",
      "primaryFaultLine",
      "institutionalInterface",
      "transmissionFailureOrBridgingMechanism",
      "continuityOutcome",
      "politicalAndFiscalConditions"
    ],
    "primaryFaultLines": [
      {
        "id": "categorical",
        "label": "Categorical",
        "definition": "Protection changes or ends when a person is reclassified across legal, administrative or programme categories."
      },
      {
        "id": "temporal",
        "label": "Temporal",
        "definition": "Protection changes or ends when an emergency, project, programme, mandate or funding period expires before displacement-related vulnerability resolves."
      },
      {
        "id": "territorial",
        "label": "Territorial",
        "definition": "Protection changes or ends when a person crosses a border, district, municipality, provider catchment or other jurisdictional boundary."
      }
    ],
    "transmissionPoints": [
      "mandate",
      "fiscal-architecture",
      "data-and-registration",
      "eligibility",
      "portability",
      "accountability",
      "delivery-capacity"
    ],
    "sustainableInclusionDomains": [
      {
        "id": "systems-integration",
        "label": "Systems integration",
        "definition": "Embedding displaced or mobile populations in ordinary public systems, service pathways, registries and administrative procedures."
      },
      {
        "id": "fiscal-integration",
        "label": "Fiscal integration",
        "definition": "Embedding displacement-related obligations in durable, recurrent or transferable public financing arrangements."
      },
      {
        "id": "sustained-institutional-responsibility",
        "label": "Sustained institutional responsibility",
        "definition": "Maintaining clear responsibility, authority and accountability across institutions, jurisdictions and displacement phases."
      }
    ],
    "politicalEconomyDimensions": [
      "membership-logic",
      "mandate-logic",
      "fiscal-exposure-logic",
      "inclusion-rationale",
      "absorption-constraint"
    ]
  },
